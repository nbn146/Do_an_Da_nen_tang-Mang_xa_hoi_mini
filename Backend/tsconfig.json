{
  "compilerOptions": {
    // 1. FILE LAYOUT: Đã bật lên để khi build, code biên dịch sẽ nằm gọn gàng trong thư mục /dist
    "rootDir": "./src",
    "outDir": "./dist",

    // 2. ENVIRONMENT
    "module": "nodenext",
    "target": "esnext",
    // Mình đã comment dòng "types": [] lại để TypeScript tự động nhận diện @types/node
    // "types": [], 

    // 3. FIX LỖI IMPORT MONGOOSE: Bật công tắc này lên!
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    // 4. OTHER OUTPUTS
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    // 5. STRICTER TYPECHECKING
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    // 6. RECOMMENDED OPTIONS
    "strict": true,
    "jsx": "react-jsx",
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true
  },
  // Bỏ qua thư mục node_modules để VS Code chạy nhẹ hơn
  "exclude": ["node_modules", "dist"]
}